    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "vercel:env": "vercel env pull",
    "cli": "tsx bin/passphrase-cli.ts",
    "cli:basic": "tsx bin/passphrase-cli.ts --generator basic",
    "cli:batch": "tsx bin/batch-generate.ts"
  },
