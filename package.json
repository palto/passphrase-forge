{
  "name": "passphrase-forge",
  "version": "2026.0.0",
  "private": true,
  "bin": {
    "passphrase": "./bin/passphrase.js"
  },
  "engines": {
    "node": ">=24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ai": "RUN_AI_TESTS=true vitest run app/passphrase/__tests__/ai-quality/",
    "check": "npm run typecheck && npm run lint && npm run prettier:check && npm run test",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "vercel:env": "vercel env pull",
    "cli": "tsx bin/passphrase-cli.ts",
    "cli:basic": "tsx bin/passphrase-cli.ts --generator basic",
    "cli:batch": "tsx bin/batch-generate.ts"
  },
  "dependencies": {
